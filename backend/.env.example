# ============================================================
# Mentora Backend — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to git!
# ============================================================

# ---------------------------
# App Settings
# ---------------------------
PORT=8000
ENV=development
# Set to "production" when deploying. Controls: debug mode, docs, CORS, logging.

# ---------------------------
# Security (REQUIRED)
# ---------------------------
# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_USE_A_STRONG_RANDOM_SECRET_KEY_HERE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------
# Database (REQUIRED)
# ---------------------------
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=mentora_db
# For MongoDB Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/
# For Docker with auth: mongodb://mentora_user:mentora_pass@mongo:27017/mentora_db

# ---------------------------
# AI / LLM API Keys
# ---------------------------
GROQ_API_KEY=your_groq_api_key_here
HF_API_KEY=your_huggingface_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ---------------------------
# Payment — SSLCommerz
# ---------------------------
SSLCOMMERZ_STORE_ID=your_sslcommerz_store_id
SSLCOMMERZ_STORE_PASSWD=your_sslcommerz_password
SSLCOMMERZ_IS_SANDBOX=True
# Set SSLCOMMERZ_IS_SANDBOX=False for live payments

# ---------------------------
# SMTP / Email Settings
# ---------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME="Mentora Support"

# ---------------------------
# URLs
# ---------------------------
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
# For LAN/mobile testing, use your machine IP instead:
# FRONTEND_URL=http://192.168.0.110:3000
# BACKEND_URL=http://192.168.0.110:8000
# Optional extra CORS origins (comma-separated):
# CORS_ORIGINS=http://192.168.0.110:3000
# Production example:
# BACKEND_URL=https://api.mentora.com
# FRONTEND_URL=https://mentora.com

# ---------------------------
# Dev-only overrides
# ---------------------------
# PAYMENT_MOCK_MODE=True   # Simulate payment success without SSLCommerz (dev only)
