# ============================================================
# Mentora — .gitignore
# ============================================================

# ---------------------------
# Environment & Secrets
# ---------------------------
.env
.env.local
.env.production
.env.staging
backend/.env
frontend/.env
frontend/.env.production
frontend/.env.local

# ---------------------------
# Python
# ---------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
backend/.venv/
backend/venv/

# ---------------------------
# Node / Frontend
# ---------------------------
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.local
.pnpm-debug.log*

# Build outputs
frontend/build/
frontend/.next/
frontend/out/
.next/

# ---------------------------
# IDE / Editor
# ---------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------
# Docker
# ---------------------------
*.env.docker

# ---------------------------
# ML / Data
# ---------------------------
backend/chroma_db/
backend/data/*.pkl
backend/data/*.bin
backend/ml_model/*.pkl
backend/ml_model/*.bin
backend/train/

# ---------------------------
# Logs
# ---------------------------
*.log
logs/
backend/logs/

# ---------------------------
# Misc / Project-Specific
# ---------------------------
backend/yay-git/
dev_docs/
*.bak
*.tmp
